# === API Keys ===
ANTHROPIC_API_KEY=sk-ant-...
ENTSO_E_API_KEY=your-entsoe-key-here

# === App ===
APP_ENV=development                  # development | staging | production
APP_NAME=voltiq
APP_VERSION=0.1.0
LOG_LEVEL=INFO

# === FastAPI ===
API_HOST=0.0.0.0              # set to 127.0.0.1 for local dev without Docker
API_PORT=8000
API_WORKERS=1
API_SECRET_KEY=change-me-in-production

# === Qdrant ===
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_COLLECTION_INCIDENTS=grid_incidents
QDRANT_COLLECTION_REPORTS=entso_reports

# === MLflow ===
MLFLOW_TRACKING_URI=http://localhost:5000
MLFLOW_EXPERIMENT_FORECAST=voltiq_forecast
MLFLOW_EXPERIMENT_ANOMALY=voltiq_anomaly

# === Airflow ===
AIRFLOW__CORE__EXECUTOR=LocalExecutor
AIRFLOW__DATABASE__SQL_ALCHEMY_CONN=sqlite:////opt/airflow/airflow.db
AIRFLOW__CORE__FERNET_KEY=change-me
AIRFLOW__WEBSERVER__SECRET_KEY=change-me

# === Azure (production) ===
AZURE_STORAGE_ACCOUNT=
AZURE_STORAGE_KEY=
AZURE_CONTAINER_NAME=voltiq-data

# === AWS (production) ===
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=eu-west-1
S3_BUCKET=voltiq-data

# === Prometheus ===
PROMETHEUS_PORT=9090

# === Model ===
FORECAST_HORIZON=48          # hours ahead to forecast
FORECAST_LOOKBACK=168        # hours of history to use (7 days)
ANOMALY_THRESHOLD=0.95       # reconstruction error percentile for alert
EMBEDDING_MODEL=BAAI/bge-small-en-v1.5
LLM_MODEL=claude-3-5-haiku-20241022
LLM_MAX_TOKENS=2048
